# ============================================================
# Banking CRM AI Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Logging ---
LOG_LEVEL=INFO                            # DEBUG, INFO, WARNING, ERROR

# --- LLM Provider ---
# Switch between "gemini" (default) and "deepseek"
LLM_PROVIDER=gemini

# Google Gemini API Key (get one at https://aistudio.google.com)
GOOGLE_API_KEY=your_gemini_api_key_here

# DeepSeek API Key (get one at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Model name — examples per provider:
#   Gemini:   gemini-2.0-flash, gemini-3.5-flash
#   DeepSeek: deepseek-chat, deepseek-reasoner
LLM_MODEL=gemini-2.0-flash

# --- API Server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./banking_crm.db

# --- Seed Data ---
NUM_CUSTOMERS=150
